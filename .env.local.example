# Skopiuj do .env.local i uzupełnij wartościami z Supabase → Project Settings → API.
# Te same dwie zmienne ustaw w Vercel → Project → Settings → Environment Variables.
#
# service_role omija RLS i jest używany WYŁĄCZNIE po stronie serwera (API routes).
# NIGDY nie trafia do przeglądarki ani do gita.

SUPABASE_URL=https://TWOJ-PROJEKT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (klucz "service_role", tylko po stronie serwera)
