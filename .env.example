# Skopiuj do .env i uzupełnij wartościami z Supabase → Project Settings → API.
# .env NIE trafia do gita. Klucz anon (publishable) jest publiczny — to OK,
# bo dostępu pilnują polityki RLS (patrz supabase/schema.sql).

VITE_SUPABASE_URL=https://TWOJ-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ... (klucz "anon"/"publishable", NIE service_role)
